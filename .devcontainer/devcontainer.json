{
  "name": "Simple AMT Ticket System",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install --upgrade pip && pip install -r backend/requirements-dev.txt",
  "forwardPorts": [8000, 5500],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode"
      ]
    }
  }
}

